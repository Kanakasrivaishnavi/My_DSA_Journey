#linear search
#time complexity - O(n)
#space complexity - O(n)
def linear_search(arr, target):
    for i in range(len(arr)):
        if arr[i] == target:
            return i
    return -1

#Binary search 
#btime complexity bestcase - O(1)
#worst case - O(log n)
#Space Complexity - O(1)
def binary_search(arr, n, target):
    low =0
    high = n-1
    while low <= high:
        mid = (low + high) //2
        if target == arr[mid]:
                        return mid
                    if target > arr[mid]:
            low = mid+1
        else:
            high = mid-1
    return -1

